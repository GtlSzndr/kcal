---
import type { Locale } from '../../types/index.ts';
import type { TranslationKeys } from '../../i18n/translations/hu.ts';
import { siteConfig } from '../../config/site.config.ts';
import ThemeToggle from '../theme/ThemeToggle.astro';
import LanguageSwitcher from '../i18n/LanguageSwitcher.astro';

interface Props {
  readonly locale: Locale;
  readonly t: TranslationKeys;
}

const { locale, t } = Astro.props;
---

<header class="glass sticky top-0 z-50 animate-slide-down">
  <div class="mx-auto flex max-w-2xl items-center justify-between gap-2 px-4 py-3">
    <div class="flex min-w-0 items-center gap-2 sm:gap-3">
      <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-gradient-to-br from-primary-400 to-accent-500 text-base shadow-md sm:h-10 sm:w-10 sm:rounded-xl sm:text-xl">
        🍽
      </div>
      <div class="min-w-0">
        <h1 class="font-display truncate text-sm font-bold tracking-tight text-surface-900 sm:text-lg dark:text-surface-50">
          {t.header.title}
        </h1>
        <p class="hidden text-xs text-surface-500 sm:block dark:text-surface-400">
          {t.header.subtitle}
        </p>
      </div>
    </div>

    <div class="flex shrink-0 items-center gap-1.5 sm:gap-2">
      {siteConfig.features.languageSwitcher && (
        <LanguageSwitcher currentLocale={locale} t={t} />
      )}
      {siteConfig.features.darkModeToggle && (
        <ThemeToggle t={t} />
      )}
    </div>
  </div>
</header>
