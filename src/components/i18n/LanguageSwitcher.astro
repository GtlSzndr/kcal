---
import type { Locale } from '../../types/index.ts';
import type { TranslationKeys } from '../../i18n/translations/hu.ts';
import { siteConfig } from '../../config/site.config.ts';
import { getLocalizedPath } from '../../i18n/index.ts';

interface Props {
  readonly currentLocale: Locale;
  readonly t: TranslationKeys;
}

const { currentLocale, t } = Astro.props;
const locales = siteConfig.i18n.locales;

const shortLabels: Record<Locale, string> = { hu: 'HU', en: 'EN' };
---

{siteConfig.features.languageSwitcher && (
  <nav aria-label={t.language.switch} class="flex items-center gap-0.5 rounded-full bg-surface-200 p-0.5 sm:gap-1 sm:p-1 dark:bg-surface-800">
    {locales.map((locale) => (
      <a
        href={getLocalizedPath(locale) + '/'}
        class:list={[
          'rounded-full px-2 py-1 text-[11px] font-semibold uppercase tracking-wider transition-all duration-300 sm:px-3 sm:py-1.5 sm:text-xs',
          locale === currentLocale
            ? 'bg-primary-500 text-white shadow-sm'
            : 'text-surface-500 hover:text-surface-900 dark:hover:text-surface-100',
        ]}
        aria-current={locale === currentLocale ? 'page' : undefined}
        hreflang={locale}
      >
        <span class="sm:hidden">{shortLabels[locale]}</span>
        <span class="hidden sm:inline">{t.language[locale]}</span>
      </a>
    ))}
  </nav>
)}
