---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, getLocalizedPath } from '../i18n/index.ts';
import { siteConfig } from '../config/site.config.ts';

const locale = siteConfig.i18n.defaultLocale;
const t = useTranslations(locale);
const homeUrl = getLocalizedPath(locale) + '/';
---

<BaseLayout
  title={t.notFound.title}
  description={t.notFound.description}
  locale={locale}
  noIndex={true}
  t={t}
>
  <div class="flex min-h-[50vh] flex-col items-center justify-center text-center">
    <div class="animate-scale-in">
      <span class="text-8xl opacity-30">🍽</span>
      <h2 class="font-display mt-6 text-3xl font-bold text-surface-800 dark:text-surface-200">
        {t.notFound.title}
      </h2>
      <p class="mt-3 text-surface-500 dark:text-surface-400">
        {t.notFound.description}
      </p>
      <p class="mt-2 text-sm text-surface-400 dark:text-surface-500">
        {t.notFound.redirect}
      </p>
      <a
        href={homeUrl}
        class="mt-6 inline-flex items-center gap-2 rounded-xl bg-primary-500 px-6 py-3 text-sm font-semibold text-white shadow-md transition-all duration-300 hover:bg-primary-600 hover:shadow-lg active:scale-[0.98]"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        {t.notFound.backHome}
      </a>
    </div>
  </div>

  <script is:inline define:vars={{ homeUrl }}>
    setTimeout(() => { window.location.href = homeUrl; }, 5000);
  </script>
</BaseLayout>
