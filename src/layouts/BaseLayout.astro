---
import type { Locale, SEOProps } from '../types/index.ts';
import type { TranslationKeys } from '../i18n/translations/hu.ts';
import SEO from '../components/seo/SEO.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props extends SEOProps {
  readonly t: TranslationKeys;
}

const { title, description, locale, canonicalUrl, ogImage, noIndex, t } = Astro.props;
---

<!doctype html>
<html lang={locale} class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/kcal/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <SEO
      title={title}
      description={description}
      locale={locale}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      noIndex={noIndex}
    />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('kcal_theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored === 'dark' || (stored !== 'light' && prefersDark);
        if (isDark) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-surface-50 text-surface-900 transition-colors duration-300 dark:bg-surface-950 dark:text-surface-100">
    <Header locale={locale} t={t} />

    <main class="mx-auto max-w-2xl px-4 py-6">
      <slot />
    </main>

    <Footer t={t} />

    <div
      id="toast-container"
      class="fixed bottom-4 left-1/2 z-50 flex -translate-x-1/2 flex-col items-center gap-2"
      aria-live="polite"
      aria-atomic="true"
    ></div>
  </body>
</html>
